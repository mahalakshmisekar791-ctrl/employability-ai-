# Environment Variables Template
# Copy this to .env and fill in your actual values

# Database Configuration
DATABASE_TYPE=postgresql  # Options: postgresql, sqlite
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/employability_ai

# Email Service (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Meeting Scheduling (Calendly)
CALENDLY_API_KEY=your_calendly_api_token_here

# LinkedIn API (when integrating)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Application Settings
ENVIRONMENT=development  # Options: development, production
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8001

# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Additional Features
ENABLE_LINKEDIN_AUTOMATION=true
ENABLE_EMAIL_AUTOMATION=true
ENABLE_SURVEY_AUTOMATION=true
ENABLE_MEETING_SCHEDULING=true
